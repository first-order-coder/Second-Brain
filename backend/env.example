# ============================================================================
# Required for Render Deployment
# ============================================================================

# OpenAI API Key (REQUIRED)
OPENAI_API_KEY=your_openai_api_key_here

# Database Configuration
# For Render: Use the Postgres connection string from Render dashboard
# For local dev: Leave as default (SQLite) or set to sqlite:///pdf_flashcards.db
DATABASE_URL=sqlite:///pdf_flashcards.db

# Supabase Configuration (Required for quota enforcement)
# Set these if you want to use Supabase as a secondary database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
POSTGRES_URL=postgresql://user:password@host:port/database

# ============================================================================
# Quota Configuration (Per-User OpenAI Usage Limits)
# ============================================================================

# Daily request limit per user (default: 50)
QUOTA_DAILY_REQUESTS=50

# Monthly token limit per user (default: 2,000,000)
QUOTA_MONTHLY_TOKENS=2000000

# Reserved tokens per request (default: 2000)
# This is the estimated token count reserved when a request is made
QUOTA_RESERVED_TOKENS=2000

# Anonymous user limits (stricter)
QUOTA_ANON_DAILY_REQUESTS=5
QUOTA_ANON_MONTHLY_TOKENS=10000

# Fallback behavior when Supabase is unavailable
# Set to true to allow requests even if quota check fails (NOT recommended for production)
QUOTA_FALLBACK_ALLOW=false

# CORS Configuration
# Comma-separated list of allowed origins
# For Render: Add your Vercel frontend URL, e.g., https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,https://YOUR_VERCEL_PROJECT.vercel.app

# ============================================================================
# Optional Feature Flags
# ============================================================================

FEATURE_SUMMARY_CITATIONS=true
FEATURE_INLINE_EDITOR=true
FEATURE_YOUTUBE_INGEST=true
ENABLE_DEBUG_ENDPOINTS=false

# Summary Configuration
SUMMARY_MODEL=gpt-4o-mini
SUMMARY_EVIDENCE_TOPK=6
SUMMARY_SUPPORT_THRESHOLD=0.74

# Celery/Redis (Optional - for background tasks)
USE_CELERY=false
REDIS_URL=redis://localhost:6379/0

# Database Read/Write Configuration
DB_READ_PRIMARY=sqlite
DB_WRITE_SQLITE=true
DB_WRITE_SUPABASE=true

# ============================================================================
# YouTube Ingestion Configuration
# ============================================================================

# YouTube language & behavior
YT_TRANSCRIPT_LANGS=en,en-US
YT_PREFER_HUMAN=true
YT_FALLBACK_ANY_LANG=true

# Robustness
YT_HTTP_TIMEOUT_SEC=15
YT_RETRY_ATTEMPTS=3
YT_RETRY_DELAY_MS=800

# Optional: consent/age/region cookies (Netscape cookies.txt format)
YT_COOKIES_FILE=
YT_COOKIES_PATH=

# yt-dlp fallback (optional, but recommended to survive consent/rate-limit)
YT_USE_YTDLP_FALLBACK=true
YT_YTDLP_PATH=yt-dlp
YT_FFMPEG_PATH=ffmpeg
YT_TMP_DIR=.cache/yt
